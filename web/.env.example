# Steady FastAPI backend (local or deployed). No trailing slash.
# Match where uvicorn (or Railway) serves the API — e.g. http://localhost:8000
NEXT_PUBLIC_STEADY_API_URL=http://localhost:8000

# The Anthropic API key is NOT set here. Put it in backend/.env as ANTHROPIC_API_KEY
# so /extract and the streaming conclusion in /advise/stream can call Claude.

# Set to 1 to show extracted-parameter debug panel after a successful extract.
# NEXT_PUBLIC_STEADY_DEBUG=0
